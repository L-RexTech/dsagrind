{
  "expo": {
    "name": "DSA Grind",
    "slug": "dsa-grind2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dsa-grind",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1117"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "backgroundColor": "#0d1117",
      "package": "com.lrextech.dsagrind"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "extra": {
      "eas": {
        "projectId": "f5ff0bd4-1094-489e-b184-f2a819ae645d"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "./plugins/dist/withAppBlocker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0d1117",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
